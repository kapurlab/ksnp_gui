<%- if host && port -%>
<div class="d-flex flex-column gap-3 py-2">
  <div class="d-flex gap-3 justify-content-center">
    <a href="/rnode/<%= host %>/<%= port %>/" target="_blank" class="btn btn-warning btn-lg px-4">
      🌳 Open kSNP4 (dev)
    </a>
  </div>
  <p class="text-center text-muted small mb-0">
    Dev session — serves the chosen git branch. Not for production data.
  </p>
</div>
<%- end -%>
