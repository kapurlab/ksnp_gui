#!/usr/bin/env bash
# kSNP4 GUI (dev) OOD batch_connect script.
# $port (uvicorn) and $worktree_dir are exported by before.sh.erb.

echo "=== kSNP4 GUI (dev) Session Starting ==="
echo "uvicorn:${port}"
echo "worktree:${worktree_dir}"

SHARED_ENV=/srv/kapurlab/tools/ksnp_gui/env
PERSONAL_ENV=/home/${USER}/miniforge3/envs/ksnp
PERSONAL_BASE_PYTHON=/home/${USER}/miniforge3/bin/python

if [ -d "${SHARED_ENV}" ] && [ -x "${SHARED_ENV}/bin/python" ]; then
  KSNP_ENV="${SHARED_ENV}"
  PYTHON="${SHARED_ENV}/bin/python"
elif [ -d "${PERSONAL_ENV}" ]; then
  KSNP_ENV="${PERSONAL_ENV}"
  PYTHON="${PERSONAL_ENV}/bin/python"
else
  KSNP_ENV=""
  PYTHON="${PERSONAL_BASE_PYTHON}"
fi

# Dev override: prefer the per-session worktree if before.sh.erb set one.
SHARED_KSNP_GUI=/srv/kapurlab/tools/ksnp_gui
if [ -n "${worktree_dir}" ] && [ -d "${worktree_dir}/backend" ]; then
  KSNP_DIR="${worktree_dir}"
else
  KSNP_DIR="${SHARED_KSNP_GUI}"
fi
# kSNP4 executables always come from the shared install (huge vendor package).
KSNP_BIN="${SHARED_KSNP_GUI}/vendor/kSNP4-bin"

export PATH="${KSNP_ENV}/bin:${KSNP_BIN}:${PATH}"
export PYTHONPATH="${KSNP_DIR}/bin:${PYTHONPATH}"

# Dev: build the frontend from the selected branch so UI changes are served.
if [ -n "${worktree_dir}" ] && [ "${KSNP_DIR}" = "${worktree_dir}" ] && [ -d "${KSNP_DIR}/frontend" ]; then
  if [ ! -e "${KSNP_DIR}/frontend/node_modules" ] && [ -d "${SHARED_KSNP_GUI}/frontend/node_modules" ]; then
    ln -s "${SHARED_KSNP_GUI}/frontend/node_modules" "${KSNP_DIR}/frontend/node_modules"
  fi
  echo "Building frontend (vite) from worktree source…"
  ( cd "${KSNP_DIR}/frontend" && npm run build ) \
    || echo "WARN: frontend build failed; serving existing dist/ if present."
fi

cd "${KSNP_DIR}/backend"
echo "Starting uvicorn on port ${port}"
echo "  conda env: ${KSNP_ENV}"
echo "  ksnp_gui:  ${KSNP_DIR}"
echo "  kSNP4 bin: ${KSNP_BIN}"
exec $PYTHON -m uvicorn app.main:app \
    --host 0.0.0.0 \
    --port "${port}" \
    --log-level info \
    --reload \
    --reload-dir app
